---
const baseUrl = import.meta.env.BASE_URL;
---

<header>
    <div class="container nav">
        <a href={baseUrl} class="logo" aria-label="Zynera inicio">
            <svg class="logo-mark" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 30V10H30" stroke="#e8c27a" stroke-width="4" stroke-linecap="square"/>
                <path d="M30 15H15V30" stroke="#e8c27a" stroke-width="2.5" stroke-linecap="square"/>
                <path d="M20 25V20H25" stroke="#e8c27a" stroke-width="1.5" stroke-linecap="square"/>
            </svg>
            <span class="logo-text">Zynera</span>
        </a>
        <div class="nav-links">
            <a href="#comparar">Estilos</a>
            <a href="#galeria">Galería</a>
            <a href="#faq">FAQ</a>
        </div>
        <button class="btn-cta" id="openContact" type="button">Probar sistema</button>
    </div>
</header>

<style>
    header {
        position: fixed;
        top: 0;
        width: 100%;
        z-index: 1000;
        background: rgba(250,250,250,0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
    }

    .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 64px;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }

    .logo-mark {
        width: 28px;
        height: 28px;
    }

    .logo-text {
        font-family: 'Playfair Display', serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text);
        letter-spacing: 3px;
    }

    .nav-links {
        display: flex;
        gap: 32px;
    }

    .nav-links a {
        color: var(--text-dim);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        transition: color 0.2s;
    }

    .nav-links a:hover {
        color: var(--text);
    }

    .btn-cta {
        background: var(--text);
        color: #fff;
        border: none;
        padding: 8px 20px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .btn-cta:hover {
        opacity: 0.85;
    }

    @media (max-width: 640px) {
        .nav-links {
            display: none;
        }
    }
</style>

<script>
    document.getElementById('openContact')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('toggle-modal'));
    });
</script>
