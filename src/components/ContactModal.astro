<div class="modal" id="contactModal">
    <div class="modal-content" id="modalContent">
        <button class="modal-close" id="closeModal">&times;</button>
        
        <!-- Progress Bar -->
        <div class="progress-container">
            <div class="progress-bar" id="progressBar"></div>
        </div>

        <div id="formWrapper">
            <form id="contactForm" enctype="multipart/form-data">
                <input type="hidden" name="access_key" value="08ec9f6d-e485-4aa6-a4f1-f56823048f86">
                <input type="hidden" name="from_name" value="Zynera Staging Wizard">
                
                <!-- STEP 1: Identification -->
                <div class="step active" data-step="1">
                    <h2 class="step-title">¿A quién le enviamos la foto?</h2>
                    <p class="step-subtitle">Ingresá tus datos para recibir el resultado procesado.</p>
                    <div class="form-group">
                        <label>Nombre Completo</label>
                        <input type="text" name="name" required placeholder="Tu nombre">
                    </div>
                    <div class="form-group">
                        <label>Email Profesional</label>
                        <input type="email" name="email" required placeholder="tu@empresa.com">
                    </div>
                    <div class="wizard-actions">
                        <button type="button" class="btn-next">Siguiente →</button>
                    </div>
                </div>

                <!-- STEP 2: Capture -->
                <div class="step" data-step="2">
                    <h2 class="step-title">Subí tu foto</h2>
                    <p class="step-subtitle">Elegí una habitación vacía o que quieras transformar.</p>
                    
                    <div class="upload-zone" id="dropZone">
                        <input type="file" name="attachment" id="fileInput" accept="image/*" class="file-input" required>
                        <div class="upload-content">
                            <span class="upload-icon">📸</span>
                            <p id="fileStatus">Arrastrá tu foto aquí o hacé clic para buscar</p>
                        </div>
                    </div>
                    
                    <div id="imagePreview" class="image-preview" style="display: none;">
                        <img src="" alt="Preview" id="previewImg">
                    </div>

                    <div class="wizard-actions">
                        <button type="button" class="btn-prev">← Volver</button>
                        <button type="button" class="btn-next">Siguiente →</button>
                    </div>
                </div>

                <!-- STEP 3: Style -->
                <div class="step" data-step="3">
                    <h2 class="step-title">Elegí el estilo</h2>
                    <p class="step-subtitle">¿Cómo te gustaría decorar este ambiente?</p>
                    
                    <div class="style-grid">
                        <label class="style-card">
                            <input type="radio" name="style" value="Mediterráneo" checked>
                            <div class="style-info">
                                <strong>Mediterráneo</strong>
                                <span>Cálido y orgánico</span>
                            </div>
                        </label>
                        <label class="style-card">
                            <input type="radio" name="style" value="Manhattan">
                            <div class="style-info">
                                <strong>Manhattan</strong>
                                <span>Industrial y lujoso</span>
                            </div>
                        </label>
                        <label class="style-card">
                            <input type="radio" name="style" value="Minimalista">
                            <div class="style-info">
                                <strong>Minimalista</strong>
                                <span>Puro y funcional</span>
                            </div>
                        </label>
                    </div>

                    <div class="wizard-actions">
                        <button type="button" class="btn-prev">← Volver</button>
                        <button type="submit" class="btn-submit" id="submitBtn">Finalizar y Enviar →</button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Success Message -->
        <div id="successMessage" style="display: none; text-align: center; padding: 40px 0;">
            <div class="success-icon">✨</div>
            <h2 style="font-family: 'Playfair Display', serif; margin-bottom: 12px;">¡Recibido con éxito!</h2>
            <p style="color: var(--text-dim); margin-bottom: 24px;">Nuestros diseñadores están procesando tu foto.<br/>Te enviaremos el resultado a tu email en menos de 24hs.</p>
            <button class="btn-contact" onclick="window.dispatchEvent(new CustomEvent('toggle-modal'))">Cerrar</button>
        </div>
    </div>
</div>

<style>
    /* --- Wizard Styles --- */
    .progress-container {
        width: 100%;
        height: 4px;
        background: rgba(255,255,255,0.05);
        position: absolute;
        top: 0;
        left: 0;
        overflow: hidden;
    }

    .progress-bar {
        height: 100%;
        background: var(--accent-color);
        width: 33.33%;
        transition: var(--transition-smooth);
    }

    .step {
        display: none;
        animation: fadeIn 0.4s ease forwards;
    }

    .step.active {
        display: block;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .step-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        margin-bottom: 8px;
    }

    .step-subtitle {
        color: var(--text-dim);
        font-size: 0.9rem;
        margin-bottom: 32px;
    }

    /* Upload Zone */
    .upload-zone {
        border: 2px dashed rgba(232, 194, 122, 0.2);
        border-radius: 12px;
        padding: 40px 20px;
        text-align: center;
        position: relative;
        transition: var(--transition-smooth);
        margin-bottom: 24px;
        cursor: pointer;
    }

    .upload-zone:hover, .upload-zone.dragover {
        background: rgba(232, 194, 122, 0.05);
        border-color: var(--accent-color);
    }

    .file-input {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        opacity: 0;
        cursor: pointer;
    }

    .upload-icon {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 16px;
    }

    .image-preview {
        width: 100%;
        max-height: 200px;
        overflow: hidden;
        border-radius: 8px;
        margin-bottom: 24px;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .image-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Style Selector */
    .style-grid {
        display: grid;
        gap: 12px;
        margin-bottom: 32px;
    }

    .style-card {
        background: #252525;
        border: 1px solid #333;
        padding: 20px;
        border-radius: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: var(--transition-smooth);
    }

    .style-card:hover {
        border-color: var(--accent-color);
    }

    .style-card input[type="radio"] {
        accent-color: var(--accent-color);
        width: 20px;
        height: 20px;
    }

    .style-info strong {
        display: block;
        color: white;
    }

    .style-info span {
        font-size: 0.8rem;
        color: var(--text-dim);
    }

    .style-card:has(input:checked) {
        border-color: var(--accent-color);
        background: rgba(232, 194, 122, 0.05);
    }

    /* Actions */
    .wizard-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        margin-top: 32px;
    }

    .btn-prev {
        background: transparent;
        border: 1px solid #444;
        color: var(--text-dim);
        padding: 12px 24px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 500;
    }

    .btn-next, .btn-submit {
        background: var(--accent-color);
        color: var(--bg-color);
        border: none;
        padding: 12px 32px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 700;
        transition: var(--transition-smooth);
    }

    .btn-next:hover, .btn-submit:hover {
        opacity: 0.9;
    }

    .success-icon {
        font-size: 4rem;
        margin-bottom: 24px;
    }

    /* Standard Modal Base */
    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.9);
        z-index: 2000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
        backdrop-filter: blur(8px);
    }

    .modal.active {
        display: flex;
    }

    .modal-content {
        background: var(--card-bg);
        padding: 48px;
        border-radius: 24px;
        max-width: 550px;
        width: 100%;
        position: relative;
        border: 1px solid rgba(255,255,255,0.1);
        box-shadow: 0 40px 100px rgba(0,0,0,0.8);
    }

    .modal-close {
        position: absolute;
        top: 24px;
        right: 24px;
        background: none;
        border: none;
        color: var(--text-dim);
        font-size: 2rem;
        cursor: pointer;
        z-index: 10;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-size: 0.9rem;
        color: var(--text-dim);
    }

    .form-group input {
        width: 100%;
        background: #252525;
        border: 1px solid #333;
        padding: 14px;
        border-radius: 8px;
        color: white;
        font-family: inherit;
    }

    .btn-contact {
        background: transparent;
        border: 1px solid var(--accent-color);
        color: var(--accent-color);
        padding: 12px 24px;
        border-radius: 50px;
        cursor: pointer;
        font-weight: 500;
    }
</style>

<script>
    const modal = document.getElementById('contactModal');
    const formWrapper = document.getElementById('formWrapper');
    const successMessage = document.getElementById('successMessage');
    const contactForm = document.getElementById('contactForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const progressBar = document.getElementById('progressBar');
    const steps = document.querySelectorAll('.step');
    const nextBtns = document.querySelectorAll('.btn-next');
    const prevBtns = document.querySelectorAll('.btn-prev');
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const dropZone = document.getElementById('dropZone');
    const fileStatus = document.getElementById('fileStatus');
    const imagePreview = document.getElementById('imagePreview');
    const previewImg = document.getElementById('previewImg') as HTMLImageElement;

    let currentStep = 1;

    // --- Navigation Logic ---
    const updateWizard = () => {
        steps.forEach(step => {
            const stepNum = parseInt(step.getAttribute('data-step') || "1");
            step.classList.toggle('active', stepNum === currentStep);
        });
        
        if (progressBar) {
            progressBar.style.width = `${(currentStep / 3) * 100}%`;
        }
    };

    nextBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            // Basic validation
            const currentStepEl = document.querySelector(`.step[data-step="${currentStep}"]`);
            const inputs = currentStepEl?.querySelectorAll('input[required]');
            let valid = true;
            
            inputs?.forEach(input => {
                if (!(input as HTMLInputElement).value) {
                    (input as HTMLInputElement).reportValidity();
                    valid = false;
                }
            });

            if (valid && currentStep < 3) {
                currentStep++;
                updateWizard();
            }
        });
    });

    prevBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            if (currentStep > 1) {
                currentStep--;
                updateWizard();
            }
        });
    });

    // --- File Handling ---
    fileInput?.addEventListener('change', (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        handleFile(file);
    });

    dropZone?.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('dragover');
    });

    dropZone?.addEventListener('dragleave', () => {
        dropZone.classList.remove('dragover');
    });

    dropZone?.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        const file = e.dataTransfer?.files[0];
        if (file) {
            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(file);
            fileInput.files = dataTransfer.files;
            handleFile(file);
        }
    });

    function handleFile(file: File | undefined) {
        if (file && file.type.startsWith('image/')) {
            if (fileStatus) fileStatus.innerText = `Foto seleccionada: ${file.name}`;
            const reader = new FileReader();
            reader.onload = (e) => {
                if (previewImg && imagePreview) {
                    previewImg.src = e.target?.result as string;
                    imagePreview.style.display = 'block';
                }
            };
            reader.readAsDataURL(file);
        }
    }

    // --- Modal Control ---
    const toggleModal = () => {
        if (modal) {
            modal.classList.toggle('active');
            if (!modal.classList.contains('active')) {
                // Reset on close
                setTimeout(() => {
                    currentStep = 1;
                    updateWizard();
                    if (formWrapper) formWrapper.style.display = 'block';
                    if (successMessage) successMessage.style.display = 'none';
                    if (imagePreview) imagePreview.style.display = 'none';
                    if (fileStatus) fileStatus.innerText = 'Arrastrá tu foto aquí o hacé clic para buscar';
                    contactForm?.reset();
                }, 500);
            }
        }
    };

    window.addEventListener('toggle-modal', toggleModal);
    document.getElementById('closeModal')?.addEventListener('click', toggleModal);

    // --- Submit Logic ---
    contactForm?.addEventListener('submit', function(e) {
        e.preventDefault();
        
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerText = 'Enviando...';
        }

        const formData = new FormData(contactForm);

        fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData
        })
        .then(async (response) => {
            if (response.status == 200) {
                if (formWrapper) formWrapper.style.display = 'none';
                if (successMessage) successMessage.style.display = 'block';
                if (progressBar) progressBar.style.width = '100%';
                
                setTimeout(() => {
                    if (modal?.classList.contains('active')) {
                        toggleModal();
                    }
                }, 10000); // 10s for wizard success
            } else {
                let json = await response.json();
                alert("Error: " + json.message);
            }
        })
        .catch(error => {
            alert("Algo salió mal. Por favor intenta de nuevo.");
        })
        .then(function() {
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerText = 'Finalizar y Enviar →';
            }
        });
    });
</script>
