---
const SUBMITKIT_URL = "https://submitkit.dev/api/f/cmqcre2ma0004sp2dmw531c4e";
---

<div class="modal" id="zyneraModal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-card">
        <div class="modal-header">
            <span class="modal-title">Try virtual staging</span>
            <button class="modal-close" id="closeModal" type="button" aria-label="Close">&times;</button>
        </div>

        <form id="wizardForm" class="wizard" novalidate>
            <div class="steps" id="stepIndicator">
                <div class="dot" data-step="1">1</div>
                <div class="line"></div>
                <div class="dot" data-step="2">2</div>
                <div class="line"></div>
                <div class="dot" data-step="3">3</div>
                <div class="line"></div>
                <div class="dot" data-step="4">4</div>
            </div>

            <div class="body">
                <div class="panel active" data-step="1">
                    <label class="label" for="name">Your name</label>
                    <input type="text" id="name" class="input" name="Nombre" placeholder="Name" required autocomplete="name">
                    <span class="err" id="nameError"></span>
                </div>

                <div class="panel" data-step="2">
                    <label class="label" for="email">Your email</label>
                    <input type="email" id="email" class="input" name="Email" placeholder="you@email.com" required autocomplete="email">
                    <span class="err" id="emailError"></span>
                </div>

                <div class="panel" data-step="3">
                    <label class="label">Photo to stage</label>
                    <div class="drop" id="dropZone">
                        <input type="file" id="photo" name="Foto" accept="image/png,image/jpeg" required hidden>
                        <div class="drop-placeholder" id="dropPlaceholder">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m17 8-5-5-5 5"/><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/></svg>
                            <span>Upload or drag a photo</span>
                            <small>PNG or JPG &middot; Max 5 MB</small>
                        </div>
                        <div class="drop-preview" id="dropPreview" style="display:none">
                            <img id="previewImg" alt="Preview">
                            <button type="button" class="drop-remove" id="dropRemove">&times;</button>
                        </div>
                    </div>
                    <span class="err" id="photoError"></span>
                </div>

                <div class="panel" data-step="4">
                    <label class="label">Preferred style</label>
                    <div class="radios">
                        <label class="radio">
                            <input type="radio" name="Estilo" value="Mediterráneo" required>
                            <span>Mediterranean</span>
                        </label>
                        <label class="radio">
                            <input type="radio" name="Estilo" value="Manhattan">
                            <span>Manhattan</span>
                        </label>
                        <label class="radio">
                            <input type="radio" name="Estilo" value="Minimalista">
                            <span>Minimalist</span>
                        </label>
                    </div>
                    <span class="err" id="styleError"></span>
                    <label class="check">
                        <input type="checkbox" name="Consentimiento" value="Acepto" required>
                        <span>I accept the <a href="/Zynera/privacidad" target="_blank" rel="noopener">privacy policy</a></span>
                    </label>
                </div>
            </div>

            <div class="nav">
                <button type="button" class="btn-back" id="btnBack" style="visibility:hidden">Back</button>
                <button type="button" class="btn-next" id="btnNext">Next</button>
                <button type="submit" class="btn-submit" id="btnSubmit" style="display:none">Send request</button>
            </div>
        </form>

        <div class="state" id="loadingState" style="display:none">
            <div class="spinner"></div>
            <p>Sending request...</p>
        </div>

        <div class="state" id="successState" style="display:none">
            <div class="icon-check">&#10003;</div>
            <h3>Request sent!</h3>
            <p>We'll be in touch shortly.</p>
            <button class="btn-reset" id="btnReset" type="button">New request</button>
        </div>

        <div class="state" id="errorState" style="display:none">
            <div class="icon-err">!</div>
            <h3>Something went wrong</h3>
            <p id="errorMsg">Please try again.</p>
            <button class="btn-retry" id="btnRetry" type="button">Try again</button>
        </div>
    </div>
</div>

<style>
    .modal {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 2000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
        backdrop-filter: blur(4px);
    }
    .modal.active { display: flex; }

    .modal-card {
        background: #fff;
        border-radius: 20px;
        max-width: 460px;
        width: 100%;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 24px 80px rgba(0,0,0,0.15);
        display: flex;
        flex-direction: column;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px;
        border-bottom: 1px solid #eee;
        flex-shrink: 0;
    }

    .modal-title {
        font-size: 0.95rem;
        font-weight: 600;
    }

    .modal-close {
        background: none;
        border: none;
        color: #999;
        font-size: 1.3rem;
        cursor: pointer;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }
    .modal-close:hover { background: #f0f0f0; color: #333; }

    .steps {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 24px 24px 0;
        flex-shrink: 0;
    }

    .dot {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: #eee;
        color: #aaa;
        font-size: 0.7rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }

    .dot.active { background: #1a1a1a; color: #fff; }
    .dot.done { background: #1a1a1a; color: #fff; opacity: 0.5; }

    .line {
        width: 32px;
        height: 2px;
        background: #eee;
        border-radius: 1px;
    }

    .wizard { flex: 1; display: flex; flex-direction: column; padding: 24px 24px 20px; min-height: 0; }
    .body { flex: 1; position: relative; }
    .panel { display: none; flex-direction: column; gap: 10px; animation: fade 0.25s ease; }
    .panel.active { display: flex; }

    @keyframes fade {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .label {
        font-size: 0.9rem;
        font-weight: 500;
        color: #333;
    }

    .input {
        width: 100%;
        padding: 11px 14px;
        background: #f7f7f7;
        border: 1px solid #eee;
        border-radius: 10px;
        color: #1a1a1a;
        font-size: 0.9rem;
        font-family: 'DM Sans', sans-serif;
        outline: none;
        transition: border-color 0.2s;
    }
    .input:focus { border-color: #999; }
    .input::placeholder { color: #bbb; }

    .err {
        font-size: 0.75rem;
        color: #e03b3b;
        min-height: 1.2em;
    }

    .drop {
        border: 1px dashed #ddd;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        position: relative;
    }

    .drop:hover, .drop.dragover {
        border-color: #999;
        background: rgba(0,0,0,0.02);
    }

    .drop-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        color: #aaa;
    }

    .drop-placeholder span { font-size: 0.85rem; }
    .drop-placeholder small { font-size: 0.7rem; color: #ccc; }

    .drop-preview {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .drop-preview img {
        max-height: 160px;
        max-width: 100%;
        border-radius: 8px;
        object-fit: contain;
    }

    .drop-remove {
        position: absolute;
        top: -8px;
        right: -8px;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: rgba(0,0,0,0.7);
        border: none;
        color: #fff;
        font-size: 0.9rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .radios {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .radio {
        flex: 1;
        min-width: 100px;
    }

    .radio input { display: none; }

    .radio span {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px 14px;
        background: #f7f7f7;
        border: 1px solid #eee;
        border-radius: 10px;
        color: #999;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s;
        text-align: center;
    }

    .radio input:checked + span {
        background: #1a1a1a;
        border-color: #1a1a1a;
        color: #fff;
    }

    .radio span:hover {
        border-color: #ccc;
        color: #333;
    }

    .check {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-top: 16px;
        cursor: pointer;
    }

    .check input[type="checkbox"] {
        margin-top: 2px;
        width: 18px;
        height: 18px;
        accent-color: #1a1a1a;
        flex-shrink: 0;
    }

    .check span {
        font-size: 0.8rem;
        color: #888;
        line-height: 1.4;
    }

    .check a { color: #1a1a1a; text-decoration: underline; }

    .nav {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 20px;
        padding-top: 16px;
        border-top: 1px solid #eee;
        flex-shrink: 0;
    }

    .btn-back {
        background: none;
        border: 1px solid #ddd;
        color: #888;
        padding: 9px 18px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: all 0.2s;
        margin-right: auto;
    }
    .btn-back:hover { border-color: #bbb; color: #333; }

    .btn-next, .btn-submit {
        background: #1a1a1a;
        border: none;
        color: #fff;
        padding: 9px 24px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: opacity 0.2s;
    }
    .btn-next:hover, .btn-submit:hover { opacity: 0.85; }
    .btn-next:disabled, .btn-submit:disabled { opacity: 0.3; cursor: not-allowed; }

    .state {
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        text-align: center;
        padding: 60px 24px;
        gap: 12px;
    }

    .spinner {
        width: 32px;
        height: 32px;
        border: 3px solid #eee;
        border-top-color: #1a1a1a;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .state p { color: #888; font-size: 0.85rem; }
    .state h3 { font-family: 'DM Sans', sans-serif; font-size: 1.1rem; font-weight: 600; }

    .icon-check {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #1a1a1a;
        color: #fff;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .icon-err {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #e03b3b;
        color: #fff;
        font-size: 1.5rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-reset, .btn-retry {
        background: none;
        border: 1px solid #ddd;
        color: #333;
        padding: 10px 28px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-reset:hover, .btn-retry:hover { border-color: #999; }
</style>

<style is:global>
    body.modal-open-zynera { overflow: hidden; }
</style>

<script>
    const MODAL = document.getElementById('zyneraModal');
    const FORM = document.getElementById('wizardForm');
    const LOADING = document.getElementById('loadingState');
    const SUCCESS = document.getElementById('successState');
    const ERROR = document.getElementById('errorState');
    const ERROR_MSG = document.getElementById('errorMsg');

    let step = 1;
    const TOTAL = 4;
    let file = null;

    const $ = (id) => document.getElementById(id);
    const show = (el) => { if (el) el.style.display = 'flex'; };
    const hide = (el) => { if (el) el.style.display = 'none'; };
    const block = (el) => { if (el) el.style.display = ''; };

    function openModal() {
        reset();
        MODAL?.classList.add('active');
        MODAL?.setAttribute('aria-hidden', 'false');
        document.body.classList.add('modal-open-zynera');
    }

    function closeModal() {
        MODAL?.classList.remove('active');
        MODAL?.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('modal-open-zynera');
    }

    function go(n) {
        step = n;
        document.querySelectorAll('.panel').forEach(p => p.classList.toggle('active', +p.dataset.step === n));
        document.querySelectorAll('.dot').forEach(d => {
            const s = +d.dataset.step;
            d.classList.toggle('active', s === n);
            d.classList.toggle('done', s < n);
        });

        $('btnBack').style.visibility = n > 1 ? 'visible' : 'hidden';
        if (n === TOTAL) {
            $('btnNext').style.display = 'none';
            $('btnSubmit').style.display = '';
        } else {
            $('btnNext').style.display = '';
            $('btnSubmit').style.display = 'none';
        }
        validate(n);
    }

    function validate(n) {
        const btn = n === TOTAL ? $('btnSubmit') : $('btnNext');
        btn.disabled = true;
        switch (n) {
            case 1: btn.disabled = $('name').value.trim().length < 2; break;
            case 2: btn.disabled = !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test($('email').value.trim()); break;
            case 3: btn.disabled = !file; break;
            case 4: btn.disabled = !FORM.querySelector('input[name="Estilo"]:checked') || !FORM.querySelector('input[name="Consentimiento"]:checked'); break;
        }
    }

    function reset() {
        FORM.reset();
        file = null;
        $('dropPlaceholder').style.display = '';
        $('dropPreview').style.display = 'none';
        $('previewImg').src = '';
        document.querySelectorAll('.err').forEach(e => e.textContent = '');
        hide(SUCCESS); hide(ERROR); block(FORM); hide(LOADING);
        go(1);
    }

    $('closeModal')?.addEventListener('click', closeModal);
    $('btnReset')?.addEventListener('click', reset);

    MODAL?.addEventListener('click', (e) => { if (e.target === MODAL) closeModal(); });
    MODAL?.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    window.addEventListener('toggle-modal', () => {
        MODAL?.classList.contains('active') ? closeModal() : openModal();
    });

    $('name')?.addEventListener('input', () => {
        const v = $('name').value.trim();
        $('nameError').textContent = v.length > 0 && v.length < 2 ? 'Minimum 2 characters' : '';
        validate(1);
    });

    $('email')?.addEventListener('input', () => {
        const v = $('email').value.trim();
        $('emailError').textContent = v.length > 0 && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? 'Invalid email' : '';
        validate(2);
    });

    const fi = $('photo');
    const dz = $('dropZone');
    fi?.addEventListener('change', () => handleFile(fi.files[0]));
    dz?.addEventListener('click', () => fi?.click());
    dz?.addEventListener('dragover', (e) => { e.preventDefault(); dz.classList.add('dragover'); });
    dz?.addEventListener('dragleave', () => dz.classList.remove('dragover'));
    dz?.addEventListener('drop', (e) => {
        e.preventDefault();
        dz.classList.remove('dragover');
        const f = e.dataTransfer?.files?.[0];
        if (f) { fi.files = e.dataTransfer.files; handleFile(f); }
    });
    $('dropRemove')?.addEventListener('click', (e) => { e.stopPropagation(); clearFile(); });

    function handleFile(f) {
        $('photoError').textContent = '';
        if (!f) { clearFile(); return; }
        const valid = ['image/png','image/jpeg'];
        if (!valid.includes(f.type)) { $('photoError').textContent = 'PNG or JPG only'; clearFile(); return; }
        if (f.size > 5 * 1024 * 1024) { $('photoError').textContent = 'Max 5 MB'; clearFile(); return; }
        file = f;
        $('dropPlaceholder').style.display = 'none';
        $('dropPreview').style.display = 'flex';
        const r = new FileReader();
        r.onload = (e) => { $('previewImg').src = e.target.result; };
        r.readAsDataURL(f);
        validate(3);
    }

    function clearFile() {
        file = null; fi.value = '';
        $('dropPlaceholder').style.display = '';
        $('dropPreview').style.display = 'none';
        $('previewImg').src = '';
        validate(3);
    }

    FORM.querySelectorAll('input[name="Estilo"]').forEach(r => r.addEventListener('change', () => validate(4)));
    FORM.querySelector('input[name="Consentimiento"]')?.addEventListener('change', () => validate(4));

    $('btnNext')?.addEventListener('click', () => { if (step < TOTAL) go(step + 1); });
    $('btnBack')?.addEventListener('click', () => { if (step > 1) go(step - 1); });

    FORM?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if ($('btnSubmit').disabled) return;

        block(LOADING); hide(FORM); hide(ERROR);

        const fd = new FormData();
        fd.append('Nombre', $('name').value.trim());
        fd.append('Email', $('email').value.trim());
        if (file) fd.append('Foto', file);
        fd.append('Estilo', FORM.querySelector('input[name="Estilo"]:checked').value);
        fd.append('Consentimiento', 'Acepto');

        try {
            await fetch('https://submitkit.dev/api/f/cmqcre2ma0004sp2dmw531c4e', {
                method: 'POST', body: fd, mode: 'no-cors',
            });
            hide(LOADING); show(SUCCESS);
        } catch {
            hide(LOADING); ERROR_MSG.textContent = 'Error sending request. Try again.'; show(ERROR);
        }
    });

    $('btnRetry')?.addEventListener('click', () => { hide(ERROR); block(FORM); });

    go(1);
</script>
