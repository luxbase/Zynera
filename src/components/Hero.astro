<section class="hero">
    <div class="container">
        <h1>Transform empty spaces into premium listings</h1>
        <p>AI-powered virtual staging in seconds across design styles</p>
        <button class="btn-primary" id="heroCta" type="button">Try with your photo</button>
    </div>
</section>

<style>
    .hero {
        padding: 180px 0 80px;
        text-align: center;
    }

    .hero h1 {
        font-size: clamp(2.8rem, 6vw, 5rem);
        line-height: 1.08;
        max-width: 820px;
        margin: 0 auto 20px;
        letter-spacing: -0.02em;
    }

    .hero p {
        color: var(--text-dim);
        font-size: 1.15rem;
        max-width: 480px;
        margin: 0 auto 40px;
        font-weight: 400;
    }

    .btn-primary {
        background: var(--text);
        color: #fff;
        border: none;
        padding: 14px 36px;
        border-radius: 10px;
        font-size: 0.95rem;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.2s;
    }

    .btn-primary:hover {
        opacity: 0.85;
        transform: translateY(-1px);
    }

    @media (max-width: 640px) {
        .hero {
            padding: 140px 0 60px;
        }
        .hero h1 {
            max-width: 340px;
        }
        .hero p {
            font-size: 1rem;
            max-width: 320px;
        }
    }
</style>

<script>
    document.getElementById('heroCta')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('toggle-modal'));
    });
</script>