---
import { t, type Lang } from '../i18n';

interface Props { lang: Lang }

const { lang } = Astro.props;
const dict = t(lang);
---
<section id="faq" class="section-padding reveal">
    <div class="container" style="max-width: 800px;">
        <div class="section-header">
            <h2>{dict.faq.heading}</h2>
        </div>
        {dict.faq.items.map((item, i) => (
            <div class="faq-item">
                <button type="button" class="faq-question" aria-expanded="false" aria-controls={`faq-answer-${i + 1}`}>
                    {item.q} <span class="faq-toggle">▼</span>
                </button>
                <div class="faq-answer" id={`faq-answer-${i + 1}`} hidden>
                    {item.a}
                </div>
            </div>
        ))}
        <div style="text-align: center; margin-top: 60px;">
            <button class="btn-wizard" id="faqWizardBtn" type="button">{dict.faq.cta}</button>
        </div>
    </div>
</section>

<style>
    .faq-item {
        background: var(--card-bg);
        border-radius: 12px;
        margin-bottom: 16px;
        overflow: hidden;
    }

    .faq-question {
        padding: 24px;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 700;
        width: 100%;
        background: transparent;
        border: 0;
        color: var(--text-main);
        font: inherit;
        text-align: left;
    }

    .faq-answer {
        padding: 0 24px 24px;
        color: var(--text-dim);
    }

    .faq-toggle {
        transition: transform 0.3s ease;
    }

    .faq-item.active .faq-toggle {
        transform: rotate(180deg);
    }

    .btn-wizard {
        background-color: var(--accent-color);
        color: var(--bg-color);
        border: none;
        padding: 14px 28px;
        border-radius: 50px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition-smooth);
    }

    .btn-wizard:hover {
        opacity: 0.9;
    }
</style>

<script>
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        const question = item.querySelector('.faq-question');
        question?.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            faqItems.forEach(i => {
                i.classList.remove('active');
                i.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
                const answer = i.querySelector('.faq-answer') as HTMLElement | null;
                if (answer) answer.hidden = true;
            });
            if (!isActive) {
                item.classList.add('active');
                question.setAttribute('aria-expanded', 'true');
                const answer = item.querySelector('.faq-answer') as HTMLElement | null;
                if (answer) answer.hidden = false;
            }
        });
    });

    document.getElementById('faqWizardBtn')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('toggle-modal'));
    });
</script>
