---
import { WHATSAPP_URL } from '../constants';
const baseUrl = import.meta.env.BASE_URL;
---

<footer>
    <div class="container footer-inner">
        <div class="footer-brand">
            <a href={baseUrl} class="footer-logo">
                <svg class="footer-mark" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 30V10H30" stroke="#e8c27a" stroke-width="4" stroke-linecap="square"/>
                    <path d="M30 15H15V30" stroke="#e8c27a" stroke-width="2.5" stroke-linecap="square"/>
                    <path d="M20 25V20H25" stroke="#e8c27a" stroke-width="1.5" stroke-linecap="square"/>
                </svg>
                Zynera
            </a>
            <p class="footer-tag">AI-powered virtual staging</p>
        </div>
        <nav class="footer-nav">
            <a href="#comparar">Estilos</a>
            <a href="#galeria">Galería</a>
            <a href="#faq">FAQ</a>
            <a href={WHATSAPP_URL} target="_blank" rel="noopener">WhatsApp</a>
            <a href={`${baseUrl}privacidad`}>Privacidad</a>
        </nav>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Zynera</p>
    </div>
</footer>

<style>
    footer {
        border-top: 1px solid var(--border);
        padding: 48px 0;
    }

    .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 24px;
    }

    .footer-logo {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text);
        text-decoration: none;
        letter-spacing: 2px;
    }

    .footer-mark {
        width: 24px;
        height: 24px;
    }

    .footer-tag {
        color: var(--text-muted);
        font-size: 0.8rem;
        margin-top: 2px;
    }

    .footer-nav {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }

    .footer-nav a {
        color: var(--text-dim);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        transition: color 0.2s;
    }

    .footer-nav a:hover {
        color: var(--text);
    }

    .footer-copy {
        color: var(--text-muted);
        font-size: 0.8rem;
        width: 100%;
        text-align: center;
        margin-top: 8px;
    }
</style>
