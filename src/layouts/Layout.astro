---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "AI-powered virtual staging — transform empty spaces into premium listings in seconds." } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 40 40' fill='none'><path d='M10 30V10H30' stroke='%23e8c27a' stroke-width='4' stroke-linecap='square'/><path d='M30 15H15V30' stroke='%23e8c27a' stroke-width='2.5' stroke-linecap='square'/><path d='M20 25V20H25' stroke='%23e8c27a' stroke-width='1.5' stroke-linecap='square'/></svg>" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@380;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg: #fafafa;
		--bg-card: #ffffff;
		--text: #1a1a1a;
		--text-dim: #8a8a8a;
		--text-muted: #b0b0b0;
		--border: rgba(0,0,0,0.06);
		--border-strong: rgba(0,0,0,0.1);
		--accent: #e8c27a;
		--accent-hover: #d4ae65;
		--radius: 16px;
		--radius-sm: 10px;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		background: var(--bg);
		color: var(--text);
		font-family: 'DM Sans', sans-serif;
		font-weight: 380;
		font-size: 16px;
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	h1, h2, h3 {
		font-family: 'Playfair Display', serif;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.container {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.section-padding {
		padding: 100px 0;
	}

	@media (max-width: 768px) {
		.section-padding {
			padding: 64px 0;
		}
	}
</style>
